      "node_tint": "#2a3a2f"
    },
    {
      "node_id": 0,
      "node_type": "video",
      "title": "Video",
      "uuid": "49745e76400c4dba99d1dca1d68964c5",
      "x": 3185.4874912358973,
      "y": 1022.5198947159915,
      "width": 1055.1216510386384,
      "height": 813.120664550858,
      "z_value": -9.956000000000024,
      "ports_visible": false,
      "shelf_visible": false,
