      "cache_key": "45b9dfd6b4eaebc49a23d0cca887cc5d123abce1cfafb63fc231c41f1fcbc869",
      "caption": "Thank you message on screen",
      "source_path": "C:\\Users\\thisg\\Desktop\\Lectures On Faith\\Pages\\Lectures on Faith20.png",
      "source_size": 1284030,
      "source_mtime": 1774981877.4102495,
